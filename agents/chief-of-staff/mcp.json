{
  "mcpServers": {
    "multica": {
      "command": "npx",
      "args": ["-y", "multica-mcp"],
      "env": { "MULTICA_TOKEN": "${MULTICA_PAT}" }
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PAT_CHIEF_OF_STAFF}" }
    },
    "slack": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    },
    "google-calendar": {
      "type": "http",
      "url": "https://calendarmcp.googleapis.com"
    }
  }
}
